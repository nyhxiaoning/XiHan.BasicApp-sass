VITE_APP_TITLE=XiHan BasicApp
VITE_APP_LOGO=/favicon.png
VITE_PORT=9800
# 开发环境留空，让请求走 VITE_DEV_PROXY_TARGET（同源转发，避免 CORS）
# 若需跨域直连后端改为 http://127.0.0.1:9708
VITE_DEV_PROXY_TARGET=http://localhost:9708
# 本地 Mock 开关：true 时使用本地 mock 数据，不依赖后端服务
VITE_USE_MOCK=true
VITE_ROUTER_HISTORY=hash
VITE_BASE=/
VITE_API_SECURITY_ENABLED=false
VITE_API_SECURITY_ACCESS_KEY=basicapp-frontend
VITE_API_SECURITY_SECRET_KEY=basicapp_frontend_signature_secret_2026
VITE_API_SECURITY_ENCRYPT_KEY=basicapp_frontend_encrypt_secret_2026
VITE_API_SECURITY_SIGN_ALGORITHM=HMACSHA256
VITE_API_SECURITY_CONTENT_SIGN_ALGORITHM=SHA256
VITE_API_SECURITY_ENCRYPT_ALGORITHM=AES-CBC
VITE_API_SECURITY_ENCRYPT_RESPONSE=true
